{
  "name": "safe-client-gateway",
  "description": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "yarn generate-abis && nest build",
    "format": "biome format --write",
    "format-check": "biome format",
    "generate-abis": "node ./scripts/generate-abis.js",
    "postinstall": "yarn generate-abis",
    "start": "node --env-file=.env node_modules/.bin/nest start",
    "start:dev": "node --env-file=.env node_modules/.bin/nest start --watch",
    "start:debug": "node --env-file=.env node_modules/.bin/nest start --debug --watch",
    "start:prod": "node --env-file=.env dist/src/main",
    "lint": "biome check --fix",
    "lint-check": "biome check",
    "test": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project unit",
    "test:watch": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest --project unit",
    "test:cov": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project unit --coverage",
    "test:debug": "TZ=UTC node --env-file-if-exists=./.env.test --inspect-brk ./node_modules/.bin/vitest run --project unit --no-file-parallelism",
    "test:unit": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project unit",
    "test:unit:cov": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project unit --coverage",
    "test:integration": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project integration",
    "test:integration:cov": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project integration --coverage",
    "test:e2e": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project e2e",
    "test:e2e:cov": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --project e2e --coverage",
    "test:all": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run",
    "test:all:cov": "TZ=UTC node --env-file-if-exists=./.env.test ./node_modules/.bin/vitest run --coverage",
    "typeorm": "node --env-file=.env -r tsconfig-paths/register ./node_modules/typeorm/cli -d ./dist/src/config/entities/orm.config.js",
    "migration:create": "node --env-file=.env -r tsconfig-paths/register ./node_modules/typeorm/cli migration:create ./migrations/${0}",
    "migration:generate": "yarn typeorm migration:generate ./migrations/${0}",
    "migration:run": "yarn typeorm migration:run",
    "migration:revert": "yarn typeorm migration:revert",
    "env:validate": "ts-node scripts/validate-env-json.ts",
    "env:validate:silent": "ts-node scripts/validate-env-json.ts --silent",
    "env:generate": "ts-node scripts/generate-env.ts",
    "env:generate:force": "ts-node scripts/generate-env.ts --force",
    "env:generate:update": "ts-node scripts/generate-env.ts --update"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "3.1076.0",
    "@aws-sdk/client-s3": "3.1076.0",
    "@aws-sdk/client-sesv2": "3.1076.0",
    "@aws-sdk/credential-provider-web-identity": "3.972.56",
    "@aws-sdk/lib-storage": "3.1076.0",
    "@aws-sdk/s3-request-presigner": "3.1076.0",
    "@blockaid/client": "^0.65.0",
    "@fingerprintjs/fingerprintjs-pro-server-api": "6.10.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "3.1.2",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/serve-static": "5.0.5",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/typeorm": "11.0.3",
    "@safe-global/safe-deployments": "1.37.56",
    "@safe-global/safe-modules-deployments": "3.0.3",
    "amqp-connection-manager": "5.0.0",
    "amqplib": "2.0.1",
    "bullmq": "^5.79.2",
    "cache-manager": "7.2.8",
    "cookie-parser": "1.4.7",
    "csv-stringify": "^6.8.0",
    "jose": "6.2.3",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "nestjs-cls": "6.2.1",
    "pg": "8.18.0",
    "postgres": "3.4.7",
    "redis": "6.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sanitize-html": "2.17.3",
    "semver": "7.7.1",
    "typeorm": "0.3.28",
    "undici": "8.5.0",
    "viem": "2.52.0",
    "winston": "3.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@faker-js/faker": "10.5.0",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@smithy/util-stream": "4.7.4",
    "@swc/core": "1.15.43",
    "@types/amqplib": "0",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.1",
    "@types/sanitize-html": "2",
    "@types/semver": "7.7.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.7",
    "aws-sdk-client-mock": "4.1.0",
    "husky": "9.1.7",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.9"
  },
  "main": "main.ts",
  "repository": "https://github.com/5afe/safe-client-gateway-nest.git",
  "packageManager": "yarn@4.14.1"
}
