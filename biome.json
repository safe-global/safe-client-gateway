{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**/src/**/*.ts",
      "**/apps/**/*.ts",
      "**/libs/**/*.ts",
      "**/test/**/*.ts",
      "**/migrations/**/*.ts"
    ]
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedPrivateClassMembers": "error",
        "useParseIntRadix": "off",
        "noVoidTypeReturn": "off"
      },
      "style": {
        "useImportType": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": {
            "syntax": "generic"
          }
        },
        "noNonNullAssertion": "off",
        "noNestedTernary": "error",
        "noParameterAssign": "error",
        "noUselessElse": "error",
        "noYodaExpression": "error",
        "useDefaultParameterLast": "error",
        "useThrowOnlyError": "error",
        "useNodejsImportProtocol": "off",
        "useTemplate": "off",
        "useLiteralEnumMembers": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@safe-global/safe-deployments": "Please import from @/domain/common/utils/deployments instead."
            }
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": "error",
        "noVar": "error",
        "noEmptyBlockStatements": "error",
        "noControlCharactersInRegex": "off",
        "noAssignInExpressions": "off",
        "noDoubleEquals": "off",
        "noGlobalIsNan": "off",
        "useIterableCallbackReturn": "off",
        "noTemplateCurlyInString": "off",
        "noImplicitAnyLet": "off",
        "noExportsInTest": "off"
      },
      "complexity": {
        "noUselessConstructor": "error",
        "noUselessSwitchCase": "error",
        "noUselessTernary": "error",
        "useOptionalChain": "error",
        "useDateNow": "error",
        "noForEach": "off",
        "noStaticOnlyClass": "off",
        "useLiteralKeys": "off",
        "noBannedTypes": "off"
      },
      "performance": {
        "noAccumulatingSpread": "error"
      },
      "security": {
        "noGlobalEval": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/src/domain/common/utils/deployments.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/logging/__tests__/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  }
}
