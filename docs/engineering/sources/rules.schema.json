{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "area",
      "title",
      "rule",
      "check",
      "exampleRefs",
      "reviewLearningIds"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9]{1,9}-[0-9]{2}$"
      },
      "project": {
        "type": "string",
        "minLength": 1
      },
      "area": {
        "type": "string",
        "minLength": 1
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "rule": {
        "type": "string",
        "minLength": 1
      },
      "check": {
        "type": "string",
        "minLength": 1
      },
      "exampleRefs": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*\\.md#[A-Za-z0-9][A-Za-z0-9_.-]*$"
        }
      },
      "reviewLearningIds": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^RL-[0-9]{8}-[0-9]{3}$"
        }
      }
    }
  }
}
